---
import { labels, localePath, locales, type Locale } from "@/lib/i18n";

type Props = {
  locale: Locale;
  merchUrl?: string | null;
};

const { locale, merchUrl = null } = Astro.props;
const t = labels[locale];
const currentPath = Astro.url.pathname.replace(/^\/(en|zh-TW|zh-CN)/, "") || "/";
const merchHref = merchUrl || localePath(locale, "/merch");
const merchExternal = Boolean(merchUrl);
---

<header class="site-nav" data-site-nav>
  <a class="brand" href={localePath(locale)} aria-label="Sam Lee home">
    <img class="brand-logo" src="/assets/logo.png" alt="Sam Lee" />
  </a>
  <nav class="desktop-nav" aria-label="Primary navigation">
    <a href={localePath(locale)}>{t.home}</a>
    <a href={localePath(locale, "/music")}>{t.music}</a>
    <a href={`${localePath(locale)}#tour`} data-scroll-tour>{t.tour}</a>
    <a href={merchHref} target={merchExternal ? "_blank" : undefined} rel={merchExternal ? "noopener noreferrer" : undefined}>
      {t.merch}
    </a>
    <a href={localePath(locale, "/about")}>{t.about}</a>
  </nav>
  <div class="nav-actions">
    <div class="language-switcher" aria-label="Language selector">
      {locales.map((item) => (
        <a class:list={[{ active: item === locale }]} href={`/${item}${currentPath === "/" ? "" : currentPath}`}>
          {item === "en" ? "EN" : item === "zh-TW" ? "繁" : "简"}
        </a>
      ))}
    </div>
    <button class="menu-button" type="button" aria-label="Open menu" aria-expanded="false" data-menu-button>
      <span></span>
      <span></span>
    </button>
  </div>
  <nav class="mobile-menu" data-mobile-menu aria-label="Mobile navigation">
    <a href={localePath(locale)}>{t.home}</a>
    <a href={localePath(locale, "/music")}>{t.music}</a>
    <a href={`${localePath(locale)}#tour`} data-scroll-tour>{t.tour}</a>
    <a href={merchHref} target={merchExternal ? "_blank" : undefined} rel={merchExternal ? "noopener noreferrer" : undefined}>
      {t.merch}
    </a>
    <a href={localePath(locale, "/about")}>{t.about}</a>
  </nav>
</header>

<style>
  .site-nav {
    position: fixed;
    inset: 0 0 auto;
    z-index: 50;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 24px;
    min-height: 72px;
    padding: 14px clamp(16px, 4vw, 48px);
    color: #fff;
    transition:
      background 180ms ease,
      border-color 180ms ease;
    border-bottom: 1px solid transparent;
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.65);
  }

  .site-nav.is-scrolled {
    background: rgba(0, 0, 0, 0.95);
    border-color: rgba(75, 187, 196, 0.3);
    backdrop-filter: blur(16px);
    box-shadow: 0 4px 30px rgba(0, 0, 0, 0.8), 0 1px 10px rgba(75, 187, 196, 0.15);
  }

  .brand {
    font-size: 1.15rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .brand-logo {
    height: 28px;
    width: auto;
    display: block;
    filter: invert(1) brightness(1.2);
  }

  .desktop-nav {
    display: flex;
    justify-content: center;
    gap: clamp(18px, 3vw, 34px);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .desktop-nav a {
    color: #fff;
    transition: color 180ms ease, text-shadow 180ms ease;
  }

  .desktop-nav a:hover {
    color: var(--cyan);
    text-shadow: 0 0 8px rgba(75, 187, 196, 0.8);
  }

  .mobile-menu a {
    color: #fff;
    transition: color 180ms ease;
  }

  .mobile-menu a:hover {
    color: var(--cyan);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .language-switcher {
    display: flex;
    gap: 6px;
  }

  .language-switcher a {
    display: grid;
    place-items: center;
    min-width: 34px;
    height: 34px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    font-size: 0.78rem;
    font-weight: 800;
    color: #fff;
    transition: all 180ms ease;
  }

  .language-switcher a:hover {
    border-color: var(--cyan);
    color: var(--cyan);
  }

  .language-switcher a.active {
    background: var(--pink);
    color: #ffffff;
    border-color: var(--pink);
    box-shadow: 0 0 10px var(--pink);
    text-shadow: none;
  }

  .menu-button {
    display: none;
    width: 42px;
    height: 42px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: rgba(0, 0, 0, 0.4);
    color: #fff;
    transition: all 180ms ease;
  }

  .menu-button:hover {
    border-color: var(--cyan);
    color: var(--cyan);
    box-shadow: 0 0 8px rgba(75, 187, 196, 0.4);
  }

  .menu-button span {
    display: block;
    width: 18px;
    height: 2px;
    margin: 5px auto;
    background: currentColor;
  }

  .mobile-menu {
    display: none;
  }

  @media (max-width: 760px) {
    .site-nav {
      grid-template-columns: 1fr auto;
    }

    .desktop-nav {
      display: none;
    }

    .menu-button {
      display: block;
    }

    .mobile-menu {
      grid-column: 1 / -1;
      display: none;
      padding: 20px 0 10px;
      border-top: 1px solid rgba(75, 187, 196, 0.25);
      gap: 18px;
      font-size: 1.35rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .mobile-menu.is-open {
      display: grid;
    }
  }
</style>
