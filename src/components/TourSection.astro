---
import { labels, localePath, getLocalized, type Locale } from "@/lib/i18n";
import type { TourDate } from "@/lib/types";

type Props = {
  locale: Locale;
  tours: TourDate[];
};

const { locale, tours } = Astro.props;
const t = labels[locale];
const now = Date.now();
---

<section class="section tour-section" id="tour">
  <div class="container">
    <h2 class="section-title">{t.tour}</h2>
    {tours.length === 0 ? (
      <div class="empty-state">{t.tourComingSoon}</div>
    ) : (
      <div class="tour-list">
        {tours.map((tour) => {
          const isPast = new Date(tour.dateUtc).getTime() < now;
          return (
            <article class:list={["tour-item", { "is-past": isPast }]}>
              <time datetime={tour.dateUtc}>
                <span>{tour.localDate}</span>
                <strong>{tour.localTime}</strong>
              </time>
              <div>
                <h3>{getLocalized(tour.location, locale)}</h3>
                <p>{getLocalized(tour.description, locale)}</p>
              </div>

              <div class="tour-action">
                {isPast ? (
                  <span class="status">{t.passed}</span>
                ) : tour.ticketLinkCount > 0 ? (
                  <a class="button" href={localePath(locale, `/tour/${tour.slug}`)}>{t.purchase}</a>
                ) : (
                  <span class="status">{t.comingSoon}</span>
                )}
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
  .tour-section {
    background: #000000;
    border-bottom: 1px solid var(--line);
  }

  .tour-list {
    display: grid;
    gap: 16px;
  }

  .tour-item {
    display: grid;
    grid-template-columns: 160px minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
    padding: 22px;
    border: 1px solid var(--line);
    background: #0a0a0c url('/assets/coming_dates_bg.jpg') no-repeat right center;
    background-size: cover;
    transition: border-color 220ms ease, box-shadow 220ms ease, transform 220ms ease;
  }

  .tour-item:not(.is-past):hover {
    border-color: var(--cyan);
    box-shadow: 0 0 15px rgba(75, 187, 196, 0.25);
    transform: translateY(-2px);
  }

  .tour-item.is-past {
    filter: grayscale(1);
    opacity: 0.45;
    background: #080808 url('/assets/past_dates_bg.jpg') no-repeat right center;
    background-size: cover;
  }

  time {
    display: grid;
    gap: 6px;
    color: var(--text-muted);
    font-weight: 700;
  }

  time strong {
    color: var(--cyan);
    font-size: 1.4rem;
    font-weight: 900;
    text-shadow: 0 0 5px rgba(75, 187, 196, 0.3);
  }

  h3 {
    margin: 0 0 8px;
    font-size: clamp(1.35rem, 3vw, 2.2rem);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  p {
    margin: 0;
    color: var(--text-muted);
  }

  .status {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 0 16px;
    border: 1px solid var(--line);
    color: var(--text-muted);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  @media (max-width: 760px) {
    .tour-item {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .tour-action {
      justify-self: start;
    }
  }
</style>
