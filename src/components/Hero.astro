---
const env = Astro.locals.runtime?.env;
const mediaBase = env?.PUBLIC_MEDIA_BASE_URL || "/media";
const videoUrl = `${mediaBase.replace(/\/$/, "")}/hero-video.mp4`;
---

<section class="hero" aria-label="Sam Lee">
  <video class="hero-video" autoplay muted loop playsinline poster="/hero-poster.jpg">
    <source src={videoUrl} type="video/mp4" />
  </video>
  <div class="hero-shade"></div>
  <div class="hero-content">
    <h1>Sam Lee</h1>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: grid;
    place-items: center;
    overflow: hidden;
    background: #080808;
  }

  .hero-video,
  .hero-shade {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero-video {
    object-fit: cover;
  }

  .hero-shade {
    background:
      linear-gradient(180deg, rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.1) 50%, #000000 100%),
      radial-gradient(circle at 50% 44%, rgba(75, 187, 196, 0.25), transparent 45%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 96px 24px;
  }

  h1 {
    margin: 0;
    font-size: clamp(4rem, 15vw, 12rem);
    line-height: 0.86;
    font-weight: 950;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    text-shadow: 0 0 15px rgba(255, 0, 127, 0.65), 0 0 40px rgba(75, 187, 196, 0.45);
  }
</style>
