---
import { labels, getLocalizedVideoUrl, type Locale } from "@/lib/i18n";
import type { VideoLink } from "@/lib/types";

type Props = {
  locale: Locale;
  videos: VideoLink[];
};

const { locale, videos } = Astro.props;
const t = labels[locale];
---

<section class="section videos">
  <div class="container">
    <h2 class="section-title">Video</h2>
    {videos.length === 0 ? (
      <div class="empty-state">{t.videoComingSoon}</div>
    ) : (
      <div class="video-strip">
        {videos.map((video) => (
          <button class="video-card" data-video-url={getLocalizedVideoUrl(video, locale)} data-video-title={video.title} type="button">
            <span class="video-img-wrapper">

              {video.thumbnail ? (
                <img src={video.thumbnail.url} alt={video.thumbnail.alt || video.title} loading="lazy" />
              ) : (
                <span class="no-thumb">{video.title}</span>
              )}
              <span class="play-icon" aria-hidden="true">▶</span>
            </span>
            <strong>{video.title}</strong>
          </button>
        ))}
      </div>
    )}
  </div>
</section>

<!-- Lightbox Modal -->
<div class="video-lightbox" id="video-lightbox" aria-hidden="true" role="dialog">
  <div class="lightbox-overlay" id="lightbox-overlay"></div>
  <button class="lightbox-nav prev" id="lightbox-prev" type="button" aria-label="Previous video">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
  </button>
  <div class="lightbox-content">
    <button class="lightbox-close" id="lightbox-close" type="button" aria-label="Close video player">&times;</button>
    <div class="iframe-container" id="iframe-container"></div>
  </div>
  <button class="lightbox-nav next" id="lightbox-next" type="button" aria-label="Next video">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
  </button>
</div>

<script>
  const lightbox = document.getElementById("video-lightbox");
  const overlay = document.getElementById("lightbox-overlay");
  const closeBtn = document.getElementById("lightbox-close");
  const prevBtn = document.getElementById("lightbox-prev");
  const nextBtn = document.getElementById("lightbox-next");
  const container = document.getElementById("iframe-container");
  const videoCards = document.querySelectorAll(".video-card");

  let currentIndex = -1;

  function getEmbedUrl(url: string): string | null {
    if (!url) return null;
    
    // YouTube
    if (url.includes("youtube.com/watch") || url.includes("youtu.be") || url.includes("youtube.com/embed")) {
      let videoId = "";
      if (url.includes("youtube.com/watch")) {
        const match = url.match(/[?&]v=([^&#]+)/);
        videoId = match ? match[1] : "";
      } else if (url.includes("youtu.be")) {
        const parts = url.split("/");
        videoId = parts[parts.length - 1];
      } else if (url.includes("youtube.com/embed")) {
        const parts = url.split("/");
        videoId = parts[parts.length - 1].split("?")[0];
      }
      return videoId ? `https://www.youtube.com/embed/${videoId}?autoplay=1&rel=0` : null;
    }
    
    // Vimeo
    if (url.includes("vimeo.com")) {
      const match = url.match(/vimeo\.com\/(\d+)/);
      const videoId = match ? match[1] : "";
      return videoId ? `https://player.vimeo.com/video/${videoId}?autoplay=1` : null;
    }

    // Bilibili
    if (url.includes("bilibili.com")) {
      const match = url.match(/video\/(BV[a-zA-Z0-9]+)/);
      const bvId = match ? match[1] : "";
      return bvId ? `https://player.bilibili.com/player.html?bvid=${bvId}&autoplay=1&high_quality=1` : null;
    }

    // Fallback
    return url;
  }

  function openLightbox(url: string, title: string) {
    const embedUrl = getEmbedUrl(url);
    if (!embedUrl || !container || !lightbox) return;

    container.innerHTML = `
      <iframe 
        src="${embedUrl}" 
        title="${title}" 
        style="width: 100%; height: 100%; display: block; border: 0;"
        scrolling="no" 
        border="0" 
        frameborder="no" 
        framespacing="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
        allowfullscreen="true">
      </iframe>
    `;

    lightbox.classList.add("is-open");
    lightbox.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  }

  function closeLightbox() {
    if (!lightbox || !container) return;
    lightbox.classList.remove("is-open");
    lightbox.setAttribute("aria-hidden", "true");
    container.innerHTML = "";
    document.body.style.overflow = "";
    currentIndex = -1;
  }

  function showVideoAtIndex(index: number) {
    if (index < 0 || index >= videoCards.length) return;
    currentIndex = index;
    const card = videoCards[index];
    const url = card.getAttribute("data-video-url") || "";
    const title = card.getAttribute("data-video-title") || "";
    
    // Update active iframe source instead of adding class list changes
    const embedUrl = getEmbedUrl(url);
    if (!embedUrl || !container) return;
    const iframe = container.querySelector("iframe");
    if (iframe) {
      iframe.src = embedUrl;
      iframe.title = title;
    } else {
      openLightbox(url, title);
    }
  }

  videoCards.forEach((card, index) => {
    card.addEventListener("click", () => {
      currentIndex = index;
      const url = card.getAttribute("data-video-url") || "";
      const title = card.getAttribute("data-video-title") || "";
      openLightbox(url, title);
    });
  });

  if (videoCards.length <= 1) {
    if (prevBtn) prevBtn.style.display = "none";
    if (nextBtn) nextBtn.style.display = "none";
  }

  prevBtn?.addEventListener("click", () => {
    let nextIdx = currentIndex - 1;
    if (nextIdx < 0) nextIdx = videoCards.length - 1;
    showVideoAtIndex(nextIdx);
  });

  nextBtn?.addEventListener("click", () => {
    let nextIdx = currentIndex + 1;
    if (nextIdx >= videoCards.length) nextIdx = 0;
    showVideoAtIndex(nextIdx);
  });

  closeBtn?.addEventListener("click", closeLightbox);
  overlay?.addEventListener("click", closeLightbox);

  // Close on Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeLightbox();
  });
</script>

<style>
  .videos {
    position: relative;
    z-index: 1;
  }

  .videos::before {
    content: "";
    position: absolute;
    inset: 0;
    background: url('/assets/brushed_bg.jpg') no-repeat center;
    background-size: 100% 100%;
    transform: scaleY(-1);
    z-index: -1;
  }

  .videos :global(.section-title) {
    color: #000000;
    text-shadow: none;
  }

  .videos :global(.section-title::after) {
    background: #000000;
    box-shadow: none;
  }

  .video-strip {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(280px, 38%);
    gap: 20px;
    overflow-x: auto;
    padding-bottom: 20px;
    scroll-snap-type: x mandatory;
    scrollbar-width: thin;
    scrollbar-color: #000000 transparent;
  }

  .video-card {
    scroll-snap-align: start;
    display: grid;
    gap: 14px;
    background: transparent;
    border: none;
    padding: 0;
    color: inherit;
    text-align: left;
    cursor: pointer;
  }

  .video-img-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(0, 0, 0, 0.15);
    display: grid;
    place-items: center;
    overflow: hidden;
    transition: border-color 220ms ease;
  }

  .video-card:hover .video-img-wrapper {
    border-color: #000000;
  }

  .video-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 300ms ease, filter 300ms ease;
  }

  .video-card:hover img {
    transform: scale(1.04);
    filter: brightness(0.85);
  }

  .no-thumb {
    font-size: 0.95rem;
    color: #4a4a4a;
    text-align: center;
    padding: 12px;
  }

  .play-icon {
    position: absolute;
    z-index: 2;
    background: rgba(0, 0, 0, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: #fff;
    width: 52px;
    height: 52px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 1.15rem;
    padding-left: 3px;
    opacity: 0.8;
    transition: all 220ms ease;
  }

  .video-card:hover .play-icon {
    opacity: 1;
    transform: scale(1.1);
    background: #000000;
    color: #ffffff;
    border-color: #000000;
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.3);
  }

  .video-card strong {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.4;
    color: #000000;
    transition: color 220ms ease;
  }

  .video-card:hover strong {
    color: #333333;
  }

  /* Lightbox Styles */
  .video-lightbox {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 24px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 220ms ease;
    padding: 24px;
  }

  .video-lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.96);
    backdrop-filter: blur(12px);
  }

  .lightbox-content {
    position: relative;
    z-index: 101;
    width: min(90vw, 960px);
    aspect-ratio: 16 / 9;
    background: #000;
    border: 2px solid var(--cyan);
    box-shadow: 0 0 35px rgba(75, 187, 196, 0.4), 0 0 80px rgba(75, 187, 196, 0.15);
  }

  .lightbox-nav {
    position: relative;
    z-index: 102;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: #fff;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 220ms ease;
  }

  .lightbox-nav:hover {
    background: rgba(0, 0, 0, 0.8);
    border-color: var(--pink);
    color: var(--pink);
    box-shadow: 0 0 12px var(--pink);
    transform: scale(1.08);
  }

  .lightbox-nav svg {
    width: 24px;
    height: 24px;
    stroke: currentColor;
  }

  .iframe-container {
    width: 100%;
    height: 100%;
  }

  .iframe-container iframe {
    width: 100%;
    height: 100%;
  }

  .lightbox-close {
    position: absolute;
    top: -44px;
    right: 0;
    background: transparent;
    border: none;
    color: #fff;
    font-size: 2.2rem;
    cursor: pointer;
    line-height: 1;
    opacity: 0.7;
    transition: opacity 180ms ease, color 180ms ease;
  }

  .lightbox-close:hover {
    opacity: 1;
    color: var(--pink);
  }

  @media (max-width: 760px) {
    .video-strip {
      grid-auto-columns: minmax(240px, 84%);
      gap: 16px;
    }
    
    .video-lightbox {
      padding: 12px;
      gap: 12px;
    }

    .lightbox-content {
      width: min(92vw, 640px);
    }

    .lightbox-nav {
      width: 38px;
      height: 38px;
    }

    .lightbox-nav svg {
      width: 18px;
      height: 18px;
    }

    .lightbox-close {
      top: -38px;
      right: 6px;
    }
  }
</style>
