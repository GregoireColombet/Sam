---
import type { PlatformLink } from "@/lib/types";
import { labels, type Locale } from "@/lib/i18n";

type Props = {
  locale: Locale;
  socialLinks: PlatformLink[];
};

const { locale, socialLinks } = Astro.props;
const t = labels[locale];
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-left">
      <div class="footer-brand">
        <img class="footer-logo" src="/assets/logo.png" alt="Sam Lee" />
      </div>
      <div class="zoommuzik-info">
        <img class="zoommuzik-logo" src="/assets/zoommuzik-logo.png" alt="Zoommuzik" />
        <span class="mention">{t.zoommuzikProduction}</span>
        <a class="contact-link" href="mailto:contact@zoommuzik.com">{t.businessInquiries}</a>
      </div>
    </div>
    {socialLinks.length > 0 && (
      <div class="socials" aria-label="Social links">
        {socialLinks.map((link) => (
          <a href={link.url} target="_blank" rel="noopener noreferrer" aria-label={link.name}>
            <img src={link.logo.url} alt={link.logo.alt || link.name} loading="lazy" />
          </a>
        ))}
      </div>
    )}
  </div>
</footer>

<style>
  .footer {
    padding: 36px 0;
    border-top: 1px solid var(--line);
    background: #000000;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 40px;
    flex-wrap: wrap;
  }

  .footer-brand {
    font-weight: 900;
    text-transform: uppercase;
  }

  .footer-logo {
    height: 22px;
    width: auto;
    display: block;
    filter: invert(1) brightness(1.2);
  }

  .zoommuzik-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-left: 1px solid var(--line);
    padding-left: 24px;
  }

  .zoommuzik-logo {
    height: 18px;
    width: auto;
    align-self: flex-start;
    filter: invert(1) brightness(1.2);
    margin-bottom: 2px;
  }

  .mention {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-link {
    font-size: 0.85rem;
    color: var(--cyan);
    transition: color 150ms ease, text-shadow 150ms ease;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-link:hover {
    color: var(--pink);
    text-shadow: 0 0 8px rgba(255, 0, 127, 0.6);
    text-decoration: none;
  }

  .socials {
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-end;
    gap: 14px;
  }

  .socials a {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
  }

  .socials img {
    width: 30px;
    height: 30px;
    object-fit: contain;
  }

  @media (max-width: 640px) {
    .footer-inner {
      align-items: stretch;
      flex-direction: column;
      gap: 28px;
    }

    .footer-left {
      flex-direction: column;
      align-items: flex-start;
      gap: 24px;
    }

    .zoommuzik-info {
      border-left: none;
      padding-left: 0;
      border-top: 1px solid var(--line);
      padding-top: 16px;
      width: 100%;
    }
  }
</style>
