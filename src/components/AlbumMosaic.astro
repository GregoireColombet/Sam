---
import { labels, localePath, type Locale } from "@/lib/i18n";
import type { AlbumCover } from "@/lib/types";

type Props = {
  locale: Locale;
  albums: AlbumCover[];
};

const { locale, albums } = Astro.props;
const t = labels[locale];
---

<section class="section albums">
  <div class="container">
    <h2 class="section-title">{t.music}</h2>
    {albums.length === 0 ? (
      <div class="empty-state">{t.albumComingSoon}</div>
    ) : (
      <a class="mosaic" href={localePath(locale, "/music")} aria-label={t.music}>
        {albums.map((album) => (
          <img src={album.image.url} alt={album.image.alt || album.title} loading="lazy" />
        ))}
      </a>
    )}
  </div>
</section>

<style>
  .albums {
    background: var(--bg-obsidian, #050508);
    background-image: radial-gradient(circle at 50% 110%, rgba(255, 0, 127, 0.08), transparent 55%);
    border-bottom: 1px solid var(--line);
  }

  .mosaic {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 16px;
  }

  .mosaic img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    filter: saturate(0.85);
    transition:
      transform 250ms cubic-bezier(0.4, 0, 0.2, 1),
      filter 250ms cubic-bezier(0.4, 0, 0.2, 1),
      box-shadow 250ms cubic-bezier(0.4, 0, 0.2, 1);
  }

  .mosaic img:hover {
    transform: scale(1.04) translateY(-2px);
    filter: saturate(1.2) contrast(1.1);
    box-shadow: 0 8px 24px rgba(255, 0, 127, 0.5), 0 0 10px rgba(255, 0, 127, 0.3);
    position: relative;
    z-index: 10;
  }

  @media (max-width: 520px) {
    .mosaic {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
  }
</style>
