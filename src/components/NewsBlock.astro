---
import { labels, getLocalized, type Locale } from "@/lib/i18n";
import type { NewsBlock } from "@/lib/types";

type Props = {
  locale: Locale;
  news: NewsBlock;
};

const { locale, news } = Astro.props;
const title = getLocalized(news.title, locale);
const body = getLocalized(news.body, locale);
const t = labels[locale];
---

<section class="news section" style={news.background ? `--news-bg: url('${news.background.url}')` : undefined}>
  <div class="scanline"></div>
  <div class="container news-card">
    <div>
      <p class="eyebrow">News</p>
      <h2>{title}</h2>
      <p>{body}</p>
    </div>
    {news.countdownAtUtc && (
      <div class="countdown" data-countdown={news.countdownAtUtc}>
        <span><strong data-days>0</strong>{t.days}</span>
        <span><strong data-hours>0</strong>{t.hours}</span>
        <span><strong data-minutes>0</strong>{t.minutes}</span>
      </div>
    )}
  </div>
</section>

<script>
  const countdown = document.querySelector("[data-countdown]");
  if (countdown) {
    const target = new Date(countdown.getAttribute("data-countdown") || "").getTime();
    const update = () => {
      const diff = Math.max(0, target - Date.now());
      const totalMinutes = Math.floor(diff / 60000);
      const days = Math.floor(totalMinutes / 1440);
      const hours = Math.floor((totalMinutes % 1440) / 60);
      const minutes = totalMinutes % 60;
      countdown.querySelector("[data-days]")!.textContent = String(days);
      countdown.querySelector("[data-hours]")!.textContent = String(hours);
      countdown.querySelector("[data-minutes]")!.textContent = String(minutes);
    };
    update();
    window.setInterval(update, 1000);
  }
</script>

<style>
  .news {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(90deg, rgba(5, 5, 8, 0.95), rgba(5, 5, 8, 0.5)),
      repeating-linear-gradient(45deg, rgba(0, 0, 0, 0) 0px, rgba(0, 0, 0, 0) 12px, rgba(75, 187, 196, 0.015) 12px, rgba(75, 187, 196, 0.015) 24px),
      var(--news-bg, linear-gradient(135deg, #0e0e12, var(--bg-obsidian, #050508)));
    background-size: cover, auto, cover;
    background-position: center;
    border-bottom: 1px solid var(--line);
  }

  .scanline {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to bottom,
      rgba(255, 255, 255, 0),
      rgba(255, 255, 255, 0) 50%,
      rgba(75, 187, 196, 0.03) 50%,
      rgba(75, 187, 196, 0.03)
    );
    background-size: 100% 4px;
    z-index: 1;
    pointer-events: none;
  }

  .scanline::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 80px;
    background: linear-gradient(to bottom, rgba(75, 187, 196, 0.06), transparent);
    animation: scanline-move 8s linear infinite;
    pointer-events: none;
  }

  @keyframes scanline-move {
    0% {
      transform: translateY(-80px);
    }
    100% {
      transform: translateY(calc(100% + 80px));
    }
  }

  .news-card {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
    min-height: 360px;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: var(--pink);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-shadow: 0 0 8px rgba(255, 0, 127, 0.5);
  }

  h2 {
    max-width: 780px;
    margin: 0;
    font-size: clamp(2.2rem, 6vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    text-transform: uppercase;
  }

  p {
    max-width: 680px;
    color: var(--text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .countdown {
    display: grid;
    grid-template-columns: repeat(3, minmax(84px, 1fr));
    gap: 12px;
  }

  .countdown span {
    min-width: 86px;
    padding: 14px;
    border: 1px solid var(--line);
    background: rgba(0, 0, 0, 0.75);
    text-align: center;
    color: var(--text-muted);
    box-shadow: 0 0 10px rgba(75, 187, 196, 0.05);
    transition: border-color 200ms ease;
  }

  .countdown span:hover {
    border-color: var(--cyan);
  }

  .countdown strong {
    display: block;
    color: var(--cyan);
    font-size: 2.2rem;
    font-weight: 900;
    text-shadow: 0 0 8px rgba(75, 187, 196, 0.4);
  }

  @media (max-width: 760px) {
    .news-card {
      grid-template-columns: 1fr;
    }
  }
</style>
