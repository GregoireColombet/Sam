---
import { labels, getLocalized, type Locale } from "@/lib/i18n";
import type { NewsBlock } from "@/lib/types";

type Props = {
  locale: Locale;
  news: NewsBlock;
};

const { locale, news } = Astro.props;
const title = getLocalized(news.title, locale);
const body = getLocalized(news.body, locale);
const t = labels[locale];
---

<section class="news section" style={news.background ? `--news-bg: url('${news.background.url}')` : undefined}>
  <div class="container news-card">
    <div>
      <p class="eyebrow">News</p>
      <h2>{title}</h2>
      <p>{body}</p>
    </div>
    {news.countdownAtUtc && (
      <div class="countdown" data-countdown={news.countdownAtUtc}>
        <span><strong data-days>0</strong>{t.days}</span>
        <span><strong data-hours>0</strong>{t.hours}</span>
        <span><strong data-minutes>0</strong>{t.minutes}</span>
      </div>
    )}
  </div>
</section>

<script>
  const countdown = document.querySelector("[data-countdown]");
  if (countdown) {
    const target = new Date(countdown.getAttribute("data-countdown") || "").getTime();
    const update = () => {
      const diff = Math.max(0, target - Date.now());
      const totalMinutes = Math.floor(diff / 60000);
      const days = Math.floor(totalMinutes / 1440);
      const hours = Math.floor((totalMinutes % 1440) / 60);
      const minutes = totalMinutes % 60;
      countdown.querySelector("[data-days]")!.textContent = String(days);
      countdown.querySelector("[data-hours]")!.textContent = String(hours);
      countdown.querySelector("[data-minutes]")!.textContent = String(minutes);
    };
    update();
    window.setInterval(update, 1000);
  }
</script>

<style>
  .news {
    background: rgb(240, 127, 128);
    border-bottom: 1px solid rgba(0, 0, 0, 0.15);
  }

  .news-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 28px;
    align-items: end;
    min-height: 360px;
  }

  .eyebrow {
    margin: 0 0 12px;
    color: #8b0000;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  h2 {
    max-width: 780px;
    margin: 0;
    font-size: clamp(2.2rem, 6vw, 6rem);
    line-height: 0.92;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: #000000;
  }

  p {
    max-width: 680px;
    color: #2b2b2b;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .countdown {
    display: grid;
    grid-template-columns: repeat(3, minmax(84px, 1fr));
    gap: 12px;
  }

  .countdown span {
    min-width: 86px;
    padding: 14px;
    border: 1px solid rgba(0, 0, 0, 0.15);
    background: #121212;
    text-align: center;
    color: var(--text-muted);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    transition: border-color 200ms ease;
  }

  .countdown span:hover {
    border-color: #000000;
  }

  .countdown strong {
    display: block;
    color: var(--cyan);
    font-size: 2.2rem;
    font-weight: 900;
    text-shadow: 0 0 8px rgba(75, 187, 196, 0.4);
  }

  @media (max-width: 760px) {
    .news-card {
      grid-template-columns: 1fr;
    }
  }
</style>
