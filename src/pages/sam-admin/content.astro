---
import AdminLayout from "@/layouts/AdminLayout.astro";

export const prerender = false;

const env = Astro.locals.runtime?.env;
const db = env?.DB;
const baseMediaUrl = (env?.PUBLIC_MEDIA_BASE_URL || "/media").replace(/\/$/, "");

let news: any = null;
let tours: any[] = [];
let albums: any[] = [];
let videos: any[] = [];
let socials: any[] = [];
let musicLinks: any[] = [];
let settings: any = null;
let mediaList: any[] = [];
let error = "";

if (db) {
  try {
    const [newsRow, toursResult, albumsResult, videosResult, socialsResult, settingsRow, mediaResult, musicLinksResult] = await Promise.all([
      db.prepare(`select * from news_blocks where id = 1`).first<any>(),
      db.prepare(`select * from tour_dates order by starts_at_utc desc`).all<any>(),
      db.prepare(`select * from album_covers order by sort_order asc`).all<any>(),
      db.prepare(`select * from video_links order by sort_order asc`).all<any>(),
      db.prepare(`select * from social_links order by sort_order asc`).all<any>(),
      db.prepare(`select * from site_settings where id = 1`).first<any>(),
      db.prepare(`select * from media_assets order by created_at desc`).all<any>(),
      db.prepare(`select * from music_platform_links order by sort_order asc`).all<any>()
    ]);

    news = newsRow || {
      title_en: "", title_zh_tw: "", title_zh_cn: "",
      body_en: "", body_zh_tw: "", body_zh_cn: "",
      background_media_id: null, countdown_at_utc: "", is_active: 0
    };
    tours = toursResult.results || [];
    albums = albumsResult.results || [];
    videos = videosResult.results || [];
    socials = socialsResult.results || [];
    musicLinks = musicLinksResult.results || [];
    settings = settingsRow || { merch_url_en: "", merch_url_zh_tw: "", merch_url_zh_cn: "", merch_is_active: 0 };
    mediaList = mediaResult.results || [];
  } catch (e: any) {
    error = e.message;
  }
} else {
  error = "Database is not available.";
}

function getMediaUrl(id: number | null) {
  if (!id) return "";
  const found = mediaList.find((m) => m.id === id);
  return found ? `${baseMediaUrl}/${found.r2_key}` : "";
}
---

<AdminLayout title="Content Manager">
  <div class="content-header">
    <h1>Content Manager</h1>
    <p class="admin-muted">Manage all trilingual marketing copy, tour dates, album listings, and media integrations.</p>
  </div>

  {error && <div class="admin-alert admin-alert-error">{error}</div>}

  <!-- Tab Buttons -->
  <div class="tab-buttons">
    <button class="tab-btn active" data-tab="news">News Block</button>
    <button class="tab-btn" data-tab="tours">Tour Dates</button>
    <button class="tab-btn" data-tab="albums">Music & Albums</button>
    <button class="tab-btn" data-tab="videos">Videos</button>
    <button class="tab-btn" data-tab="socials-merch">Socials & Merch</button>
  </div>

  <!-- Tab Contents -->
  <div class="tab-contents">
    
    <!-- NEWS TAB -->
    <div class="tab-pane active" id="tab-news">
      <form id="news-form" class="admin-form card-form">
        <h2>News Banner Settings</h2>
        
        <div class="form-grid">
          <div class="form-group">
            <label>Title (English)</label>
            <input type="text" name="title_en" value={news.title_en} required />
          </div>
          <div class="form-group">
            <label>Title (Traditional Chinese)</label>
            <input type="text" name="title_zh_tw" value={news.title_zh_tw} required />
          </div>
          <div class="form-group">
            <label>Title (Simplified Chinese)</label>
            <input type="text" name="title_zh_cn" value={news.title_zh_cn} required />
          </div>
        </div>

        <div class="form-grid">
          <div class="form-group">
            <label>Body Text (English)</label>
            <textarea name="body_en" rows="3" required>{news.body_en}</textarea>
          </div>
          <div class="form-group">
            <label>Body Text (Traditional Chinese)</label>
            <textarea name="body_zh_tw" rows="3" required>{news.body_zh_tw}</textarea>
          </div>
          <div class="form-group">
            <label>Body Text (Simplified Chinese)</label>
            <textarea name="body_zh_cn" rows="3" required>{news.body_zh_cn}</textarea>
          </div>
        </div>

        <div class="form-grid">
          <!-- Background Image Picker -->
          <div class="form-group">
            <label>Background Image</label>
            <div class="media-picker-control" data-field="background_media_id">
              <input type="hidden" name="background_media_id" value={news.background_media_id || ""} />
              <div class="picker-preview">
                {news.background_media_id ? (
                  <img src={getMediaUrl(news.background_media_id)} alt="Selected Background" />
                ) : (
                  <span class="no-img">No Image Selected</span>
                )}
              </div>
              <div class="picker-actions">
                <button type="button" class="btn-select-media">Select Image</button>
                <button type="button" class="btn-clear-media" style={news.background_media_id ? "" : "display:none;"}>Clear</button>
              </div>
            </div>
          </div>

          <!-- Countdown Picker -->
          <div class="form-group">
            <label>Countdown Target (UTC Date/Time)</label>
            <input 
              type="datetime-local" 
              name="countdown_at_utc" 
              value={news.countdown_at_utc ? news.countdown_at_utc.slice(0, 16) : ""} 
            />
            <span class="field-hint">Leave blank to disable the countdown clock. Use UTC time.</span>
          </div>

          <!-- Status toggle -->
          <div class="form-group row-group">
            <input type="checkbox" id="news-active" name="is_active" checked={news.is_active === 1} />
            <label for="news-active">Display News block on website</label>
          </div>
        </div>

        <button type="submit" class="btn-submit">Save News settings</button>
      </form>
    </div>

    <!-- TOURS TAB -->
    <div class="tab-pane" id="tab-tours">
      <div class="actions-bar">
        <h2>Tour Schedule</h2>
        <button class="btn-primary" id="btn-add-tour">Add Tour Date</button>
      </div>

      <!-- Tour Dates Table -->
      <table class="admin-table">
        <thead>
          <tr>
            <th>Date & Time</th>
            <th>Location (EN / 繁 / 简)</th>
            <th>Description (TW)</th>
            <th>Links</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {tours.length === 0 ? (
            <tr>
              <td colspan="6" class="admin-muted" style="text-align: center; padding: 24px;">No tour dates scheduled.</td>
            </tr>
          ) : (
            tours.map((t) => (
              <tr data-tour-id={t.id}>
                <td>
                  <strong>{t.local_date}</strong>
                  <span class="time-meta">{t.local_time} ({t.timezone})</span>
                </td>
                <td>
                  <div>EN: {t.location_en}</div>
                  <div>繁: {t.location_zh_tw}</div>
                  <div>简: {t.location_zh_cn}</div>
                </td>
                <td class="admin-muted" style="max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                  {t.description_zh_tw}
                </td>
                <td>
                  <button class="btn-manage-links" data-id={t.id} data-location={t.location_zh_tw}>
                    Ticket Links
                  </button>
                </td>
                <td>
                  <span class:list={["badge", t.is_active === 1 ? "badge-active" : "badge-inactive"]}>
                    {t.is_active === 1 ? "Active" : "Hidden"}
                  </span>
                </td>
                <td>
                  <button class="btn-edit-tour" data-tour={JSON.stringify(t)}>Edit</button>
                  <button class="btn-delete-tour delete-btn" data-id={t.id}>Delete</button>
                </td>
              </tr>
            ))
          )}
        </tbody>
      </table>
    </div>

    <!-- ALBUMS TAB -->
    <div class="tab-pane" id="tab-albums">
      <form id="albums-form" class="admin-form card-form">
        <div class="actions-bar">
          <h2>Album Covers (Mosaic Grid)</h2>
          <button type="button" class="btn-primary" id="btn-add-album-row">Add Cover</button>
        </div>
        <p class="admin-muted">Add album covers here. Order is set by sorting position. Albums link to the public Music page.</p>
        
        <div class="sortable-list" id="albums-container">
          {albums.map((album, index) => (
            <div class="sortable-row" data-index={index}>
              <div class="drag-handle">⋮⋮</div>
              <div class="form-group">
                <label>Album Title</label>
                <input type="text" class="album-title" value={album.title} required />
              </div>
              <div class="form-group">
                <label>Cover Image</label>
                <div class="media-picker-control" data-field={`album_img_${index}`}>
                  <input type="hidden" class="album-media-id" value={album.image_media_id} />
                  <div class="picker-preview select-sm">
                    <img src={getMediaUrl(album.image_media_id)} alt={album.title} />
                  </div>
                  <div class="picker-actions">
                    <button type="button" class="btn-select-media btn-xs">Select</button>
                  </div>
                </div>
              </div>
              <div class="form-group checkbox-cell">
                <input type="checkbox" class="album-active" checked={album.is_active === 1} id={`album-active-${index}`} />
                <label for={`album-active-${index}`}>Active</label>
              </div>
              <button type="button" class="btn-remove-row remove-btn">Remove</button>
            </div>
          ))}
          {albums.length === 0 && <div class="empty-list-msg">No album covers listed. Click "Add Cover" to populate.</div>}
        </div>
        
        <button type="submit" class="btn-submit">Save Albums Layout</button>
      </form>

      <form id="music-links-form" class="admin-form card-form" style="margin-top: 2rem;">
        <div class="actions-bar">
          <h2>Music Streaming Platforms</h2>
          <button type="button" class="btn-primary" id="btn-add-music-row">Add Music Platform</button>
        </div>
        <p class="admin-muted">Add streaming platforms (e.g. Spotify, Apple Music) displayed on the music page. Select logo PNGs/SVGs and input URLs.</p>

        <div class="sortable-list" id="music-links-container">
          {musicLinks.map((link, index) => (
            <div class="sortable-row" data-index={index}>
              <div class="drag-handle">⋮⋮</div>
              <div class="form-group">
                <label>Platform Name</label>
                <input type="text" class="music-name" value={link.name} required placeholder="Spotify, Apple Music" />
              </div>
              <div class="form-group">
                <label>Target URL</label>
                <input type="url" class="music-url" value={link.url} required placeholder="https://..." />
              </div>
              <div class="form-group">
                <label>Logo Icon</label>
                <div class="media-picker-control" data-field={`music_logo_${index}`}>
                  <input type="hidden" class="music-media-id" value={link.logo_media_id} />
                  <div class="picker-preview select-sm">
                    <img src={getMediaUrl(link.logo_media_id)} alt={link.name} />
                  </div>
                  <div class="picker-actions">
                    <button type="button" class="btn-select-media btn-xs">Select</button>
                  </div>
                </div>
              </div>
              <div class="form-group checkbox-cell">
                <input type="checkbox" class="music-active" checked={link.is_active === 1} id={`music-active-${index}`} />
                <label for={`music-active-${index}`}>Active</label>
              </div>
              <button type="button" class="btn-remove-row remove-btn">Remove</button>
            </div>
          ))}
          {musicLinks.length === 0 && <div class="empty-list-msg">No music platform links configured. Click "Add Music Platform".</div>}
        </div>

        <button type="submit" class="btn-submit">Save Music Platforms</button>
      </form>
    </div>

    <!-- VIDEOS TAB -->
    <div class="tab-pane" id="tab-videos">
      <form id="videos-form" class="admin-form card-form">
        <div class="actions-bar">
          <h2>Carousel Playable Videos</h2>
          <button type="button" class="btn-primary" id="btn-add-video-row">Add Video</button>
        </div>
        <p class="admin-muted">Set up playable video thumbnails. Provide standard urls from YouTube, Vimeo, or R2 links. You can configure localized URLs for Simplified Chinese regions if needed.</p>

        <div class="sortable-list" id="videos-container">
          {videos.map((vid, index) => (
            <div class="sortable-row video-row" data-index={index}>
              <div class="drag-handle">⋮⋮</div>
              <div class="video-grid-inputs">
                <div class="form-grid">
                  <div class="form-group">
                    <label>Video Title</label>
                    <input type="text" class="video-title" value={vid.title} required />
                  </div>
                  <div class="form-group">
                    <label>Thumbnail Cover</label>
                    <div class="media-picker-control" data-field={`video_thumb_${index}`}>
                      <input type="hidden" class="video-thumbnail-id" value={vid.thumbnail_media_id || ""} />
                      <div class="picker-preview select-sm">
                        {vid.thumbnail_media_id ? (
                          <img src={getMediaUrl(vid.thumbnail_media_id)} alt={vid.title} />
                        ) : (
                          <span class="no-img">No Image</span>
                        )}
                      </div>
                      <div class="picker-actions">
                        <button type="button" class="btn-select-media btn-xs">Select</button>
                      </div>
                    </div>
                  </div>
                  <div class="form-group checkbox-cell">
                    <input type="checkbox" class="video-active" checked={vid.is_active === 1} id={`video-active-${index}`} />
                    <label for={`video-active-${index}`}>Active</label>
                  </div>
                </div>

                <div class="form-grid pt-2">
                  <div class="form-group">
                    <label>URL (English)</label>
                    <input type="url" class="video-url-en" value={vid.url_en} required placeholder="https://youtube.com/watch?v=..." />
                  </div>
                  <div class="form-group">
                    <label>URL (Traditional Chinese)</label>
                    <input type="url" class="video-url-zh-tw" value={vid.url_zh_tw} required placeholder="https://youtube.com/watch?v=..." />
                  </div>
                  <div class="form-group">
                    <label>URL (Simplified Chinese)</label>
                    <input type="url" class="video-url-zh-cn" value={vid.url_zh_cn} required placeholder="e.g. Bilibili link for CN region" />
                  </div>
                </div>
              </div>
              <button type="button" class="btn-remove-row remove-btn">Remove</button>
            </div>
          ))}
          {videos.length === 0 && <div class="empty-list-msg">No videos configured. Click "Add Video" to populate.</div>}
        </div>

        <button type="submit" class="btn-submit">Save Video Carousel</button>
      </form>
    </div>

    <!-- SOCIALS & MERCH TAB -->
    <div class="tab-pane" id="tab-socials-merch">
      <!-- Merch Form -->
      <form id="merch-form" class="admin-form card-form mb-4">
        <h2>Merchandising External Shop Settings</h2>
        <p class="admin-muted">Configure external shops (e.g. Shopee, Shopify) per language. If inactive, the public shop link redirects to "Coming soon".</p>
        
        <div class="form-grid">
          <div class="form-group">
            <label>Shop URL (English)</label>
            <input type="url" name="merch_url_en" value={settings.merch_url_en} placeholder="https://..." />
          </div>
          <div class="form-group">
            <label>Shop URL (Traditional Chinese)</label>
            <input type="url" name="merch_url_zh_tw" value={settings.merch_url_zh_tw} placeholder="https://..." />
          </div>
          <div class="form-group">
            <label>Shop URL (Simplified Chinese)</label>
            <input type="url" name="merch_url_zh_cn" value={settings.merch_url_zh_cn} placeholder="https://..." />
          </div>
        </div>

        <div class="form-group row-group">
          <input type="checkbox" id="merch-active" name="merch_is_active" checked={settings.merch_is_active === 1} />
          <label for="merch-active">Enable merchandising redirect links</label>
        </div>

        <button type="submit" class="btn-submit">Save Merch Settings</button>
      </form>

      <!-- Socials Form -->
      <form id="socials-form" class="admin-form card-form">
        <div class="actions-bar">
          <h2>Footer Social Platforms</h2>
          <button type="button" class="btn-primary" id="btn-add-social-row">Add Platform</button>
        </div>
        <p class="admin-muted">Add social links displayed in the footer. Upload clean, colored or monochrome logo PNG/SVGs to R2 and reference them below.</p>

        <div class="sortable-list" id="socials-container">
          {socials.map((soc, index) => (
            <div class="sortable-row" data-index={index}>
              <div class="drag-handle">⋮⋮</div>
              <div class="form-group">
                <label>Platform Name</label>
                <input type="text" class="social-name" value={soc.name} required placeholder="Spotify, YouTube, Instagram" />
              </div>
              <div class="form-group">
                <label>Target URL</label>
                <input type="url" class="social-url" value={soc.url} required placeholder="https://..." />
              </div>
              <div class="form-group">
                <label>Custom Logo (R2)</label>
                <div class="media-picker-control" data-field={`social_logo_${index}`}>
                  <input type="hidden" class="social-media-id" value={soc.logo_media_id} />
                  <div class="picker-preview select-sm">
                    <img src={getMediaUrl(soc.logo_media_id)} alt={soc.name} />
                  </div>
                  <div class="picker-actions">
                    <button type="button" class="btn-select-media btn-xs">Select</button>
                  </div>
                </div>
              </div>
              <div class="form-group checkbox-cell">
                <input type="checkbox" class="social-active" checked={soc.is_active === 1} id={`social-active-${index}`} />
                <label for={`social-active-${index}`}>Active</label>
              </div>
              <button type="button" class="btn-remove-row remove-btn">Remove</button>
            </div>
          ))}
          {socials.length === 0 && <div class="empty-list-msg">No social links configured. Click "Add Platform".</div>}
        </div>

        <button type="submit" class="btn-submit">Save Social Links</button>
      </form>
    </div>

  </div>

  <!-- MEDIA PICKER MODAL (HIDDEN BY DEFAULT) -->
  <div class="admin-modal" id="media-picker-modal">
    <div class="modal-content">
      <header class="modal-header">
        <h3>Select Media Asset</h3>
        <button type="button" class="btn-close-modal" id="btn-close-media-modal">&times;</button>
      </header>
      <div class="modal-body">
        <div class="media-search-bar">
          <input type="text" id="media-search-input" placeholder="Search files by name..." />
        </div>
        <div class="modal-media-grid" id="modal-media-grid">
          {mediaList.map((m) => (
            <div class="modal-media-item" data-id={m.id} data-url={`${baseMediaUrl}/${m.r2_key}`} data-name={m.file_name}>
              <img src={`${baseMediaUrl}/${m.r2_key}`} alt={m.alt_text || m.file_name} />
              <span class="modal-item-name" title={m.file_name}>{m.file_name}</span>
            </div>
          ))}
          {mediaList.length === 0 && <div class="admin-muted" style="grid-column: 1/-1; text-align: center; padding: 24px;">No media assets. Go to "Media" tab to upload images first.</div>}
        </div>
      </div>
    </div>
  </div>

  <!-- TOUR EDITOR MODAL (HIDDEN BY DEFAULT) -->
  <div class="admin-modal" id="tour-editor-modal">
    <div class="modal-content modal-lg">
      <header class="modal-header">
        <h3 id="tour-modal-title">Add Tour Date</h3>
        <button type="button" class="btn-close-modal" id="btn-close-tour-modal">&times;</button>
      </header>
      <div class="modal-body">
        <form id="tour-editor-form" class="admin-form">
          <input type="hidden" name="id" id="tour-id" />
          
          <div class="form-grid">
            <div class="form-group">
              <label for="tour-local-date">Local Date</label>
              <input type="date" id="tour-local-date" name="local_date" required />
            </div>
            <div class="form-group">
              <label for="tour-local-time">Local Time</label>
              <input type="time" id="tour-local-time" name="local_time" required />
            </div>
            <div class="form-group">
              <label for="tour-timezone">Timezone</label>
              <input type="text" id="tour-timezone" name="timezone" placeholder="Asia/Taipei" required />
            </div>
          </div>

          <div class="form-group">
            <label for="tour-starts-utc">Ticketing Starts At (UTC)</label>
            <input type="datetime-local" id="tour-starts-utc" name="starts_at_utc" required />
            <span class="field-hint">Chronological order sorter.</span>
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label for="tour-loc-en">Location (English)</label>
              <input type="text" id="tour-loc-en" name="location_en" required placeholder="Legacy Taipei" />
            </div>
            <div class="form-group">
              <label for="tour-loc-tw">Location (Traditional Chinese)</label>
              <input type="text" id="tour-loc-tw" name="location_zh_tw" required placeholder="華山 Legacy Taipei" />
            </div>
            <div class="form-group">
              <label for="tour-loc-cn">Location (Simplified Chinese)</label>
              <input type="text" id="tour-loc-cn" name="location_zh_cn" required placeholder="华山 Legacy Taipei" />
            </div>
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label for="tour-desc-en">Description (English)</label>
              <textarea id="tour-desc-en" name="description_en" rows="2" required></textarea>
            </div>
            <div class="form-group">
              <label for="tour-desc-tw">Description (Traditional Chinese)</label>
              <textarea id="tour-desc-tw" name="description_zh_tw" rows="2" required></textarea>
            </div>
            <div class="form-group">
              <label for="tour-desc-cn">Description (Simplified Chinese)</label>
              <textarea id="tour-desc-cn" name="description_zh_cn" rows="2" required></textarea>
            </div>
          </div>

          <div class="form-group row-group">
            <input type="checkbox" id="tour-active" name="is_active" checked />
            <label for="tour-active">Active (Visible on landing page)</label>
          </div>

          <button type="submit" class="btn-submit" id="btn-save-tour">Save Tour Date</button>
        </form>
      </div>
    </div>
  </div>

  <!-- TICKET LINKS MODAL (HIDDEN BY DEFAULT) -->
  <div class="admin-modal" id="ticket-links-modal">
    <div class="modal-content modal-lg">
      <header class="modal-header">
        <h3 id="ticket-modal-title">Ticket Links</h3>
        <button type="button" class="btn-close-modal" id="btn-close-ticket-modal">&times;</button>
      </header>
      <div class="modal-body">
        <p class="admin-muted">Manage platforms selling tickets for this show. Reorder or toggle status below.</p>
        <form id="ticket-links-form" class="admin-form">
          <input type="hidden" id="ticket-tour-id" />
          
          <div class="sortable-list" id="ticket-links-container">
            <!-- Dynamically populated -->
          </div>
          
          <div class="pt-2" style="display: flex; gap: 12px;">
            <button type="button" class="btn-primary" id="btn-add-ticket-row">Add Platform Link</button>
            <button type="submit" class="btn-submit" style="margin-top:0;">Save Ticket Links</button>
          </div>
        </form>
      </div>
    </div>
  </div>

</AdminLayout>



<script src="./content.client.ts"></script>


<style>
  .content-header {
    margin-bottom: 28px;
  }

  /* Tabs Navigation styling */
  .tab-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    border-bottom: 1px solid var(--admin-line);
    margin-bottom: 32px;
  }

  .tab-btn {
    min-height: 44px;
    padding: 0 20px;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--admin-muted);
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: color 180ms ease, border-color 180ms ease;
