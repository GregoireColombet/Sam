---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { formatBytes } from "@/lib/utils";

export const prerender = false;

const env = Astro.locals.runtime?.env;
const db = env?.DB;
const baseMediaUrl = (env?.PUBLIC_MEDIA_BASE_URL || "/media").replace(/\/$/, "");

let mediaList: any[] = [];
let error = "";

if (db) {
  try {
    const result = await db.prepare(
      `select * from media_assets order by created_at desc`
    ).all();
    mediaList = result.results || [];
  } catch (e: any) {
    error = e.message;
  }
} else {
  error = "Database binding is not available.";
}


---

<AdminLayout title="Media Library">
  <div class="media-header">
    <div>
      <h1>Media Library</h1>
      <p class="admin-muted">Upload and manage image assets for news backgrounds, album covers, and social logos.</p>
    </div>
    <label class="upload-btn">
      Upload File
      <input type="file" id="media-file-input" accept="image/png, image/jpeg, image/webp" style="display: none;" />
    </label>
  </div>

  {error && <div class="admin-alert admin-alert-error">{error}</div>}

  <!-- Drop Zone -->
  <div class="drop-zone" id="media-drop-zone">
    <span class="drop-zone-text">Drag and drop files here or click "Upload File" (PNG, JPG, WEBP only)</span>
  </div>

  <div class="media-grid" id="media-grid">
    {mediaList.length === 0 ? (
      <div class="empty-media" id="empty-media-msg">No media assets uploaded yet.</div>
    ) : (
      mediaList.map((asset) => (
        <div class="media-card" data-asset-id={asset.id}>
          <div class="media-preview">
            <img src={`${baseMediaUrl}/${asset.r2_key}`} alt={asset.alt_text || asset.file_name} />
          </div>
          <div class="media-details">
            <strong class="media-name" title={asset.file_name}>{asset.file_name}</strong>
            <span class="media-meta">{formatBytes(asset.size_bytes)} · {asset.content_type.split("/")[1].toUpperCase()}</span>
            <input type="text" class="media-url-input" readonly value={`${baseMediaUrl}/${asset.r2_key}`} title="Click to copy URL" />
            <button class="delete-btn" data-id={asset.id}>Delete</button>
          </div>
        </div>
      ))
    )}
  </div>
</AdminLayout>

<script>
  import { formatBytes } from "@/lib/utils";

  const fileInput = document.getElementById("media-file-input") as HTMLInputElement;
  const dropZone = document.getElementById("media-drop-zone");
  const mediaGrid = document.getElementById("media-grid");
  const emptyMsg = document.getElementById("empty-media-msg");

  // Handle upload
  async function uploadFile(file: File) {
    if (!file) return;
    
    // Show loading indicator
    const btn = document.querySelector(".upload-btn") as HTMLElement;
    const originalText = btn.textContent;
    btn.textContent = "Uploading...";
    btn.style.opacity = "0.7";
    btn.style.pointerEvents = "none";

    const formData = new FormData();
    formData.append("file", file);
    formData.append("alt", file.name.split(".")[0]);

    try {
      const response = await fetch("/sam-admin/api/media/upload", {
        method: "POST",
        body: formData
      });

      if (!response.ok) {
        const err = await response.json() as any;
        throw new Error(err.error || "Upload failed");
      }

      const data = await response.json() as any;
      
      // Remove empty message if it exists
      if (emptyMsg) emptyMsg.remove();

      // Prepend to grid
      const card = document.createElement("div");
      card.className = "media-card";
      card.setAttribute("data-asset-id", data.id);
      card.innerHTML = `
        <div class="media-preview">
          <img src="${data.url}" alt="${file.name}" />
        </div>
        <div class="media-details">
          <strong class="media-name" title="${file.name}">${file.name}</strong>
          <span class="media-meta">${formatBytes(file.size)} · ${file.type.split("/")[1].toUpperCase()}</span>
          <input type="text" class="media-url-input" readonly value="${data.url}" title="Click to copy URL" />
          <button class="delete-btn" data-id="${data.id}">Delete</button>
        </div>
      `;

      // Copy url action for new card
      const input = card.querySelector(".media-url-input") as HTMLInputElement;
      input.addEventListener("click", () => {
        input.select();
        navigator.clipboard.writeText(input.value);
        alert("URL copied to clipboard!");
      });

      // Delete action for new card
      card.querySelector(".delete-btn")?.addEventListener("click", () => handleDelete(data.id, file.name));

      if (mediaGrid) {
        mediaGrid.insertBefore(card, mediaGrid.firstChild);
      }
    } catch (e: any) {
      alert("Error: " + e.message);
    } finally {
      btn.textContent = originalText;
      btn.style.opacity = "";
      btn.style.pointerEvents = "";
    }
  }

  // Handle delete
  async function handleDelete(id: number, name: string) {
    if (!confirm(`Are you sure you want to delete "${name}"?`)) return;

    try {
      const response = await fetch("/sam-admin/api/media/delete", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ id })
      });

      if (!response.ok) {
        const err = await response.json() as any;
        throw new Error(err.error || "Delete failed");
      }

      // Remove from UI
      const card = document.querySelector(`[data-asset-id="${id}"]`);
      card?.remove();
      
      if (mediaGrid?.children.length === 0) {
        const msg = document.createElement("div");
        msg.className = "empty-media";
        msg.id = "empty-media-msg";
        msg.textContent = "No media assets uploaded yet.";
        mediaGrid.appendChild(msg);
      }
    } catch (e: any) {
      alert("Error: " + e.message);
    }
  }

  // Setup event listeners
  fileInput?.addEventListener("change", () => {
    const files = fileInput.files;
    if (files && files.length > 0) {
      uploadFile(files[0]);
    }
  });

  document.querySelectorAll(".delete-btn").forEach((btn) => {
    const id = Number(btn.getAttribute("data-id"));
    const name = btn.closest(".media-card")?.querySelector(".media-name")?.textContent || "this asset";
    btn.addEventListener("click", () => handleDelete(id, name));
  });

  // Setup Copy to Clipboard for server-rendered assets
  document.querySelectorAll(".media-url-input").forEach((input: any) => {
    input.addEventListener("click", () => {
      input.select();
      navigator.clipboard.writeText(input.value);
      alert("URL copied to clipboard!");
    });
  });

  // Drag and drop events
  if (dropZone) {
    ["dragenter", "dragover"].forEach((eventName) => {
      dropZone.addEventListener(eventName, (e) => {
        e.preventDefault();
        dropZone.classList.add("highlight");
      }, false);
    });

    ["dragleave", "drop"].forEach((eventName) => {
      dropZone.addEventListener(eventName, (e) => {
        e.preventDefault();
        dropZone.classList.remove("highlight");
      }, false);
    });

    dropZone.addEventListener("drop", (e: DragEvent) => {
      const dt = e.dataTransfer;
      const files = dt?.files;
      if (files && files.length > 0) {
        uploadFile(files[0]);
      }
    });
  }
</script>

<style is:global>
  .media-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .upload-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #7d5b2f;
    color: #fff;
    font-weight: 700;
    min-height: 40px;
    padding: 0 20px;
    cursor: pointer;
    border-radius: 4px;
    transition: background 180ms ease;
  }

  .upload-btn:hover {
    background: #966f3e;
  }

  .admin-alert {
    padding: 12px 16px;
    border-left: 3px solid #e55353;
    background: rgba(229, 83, 83, 0.08);
    color: #d64a4a;
    margin-bottom: 24px;
  }

  .drop-zone {
    border: 2px dashed var(--admin-line);
    background: var(--admin-panel);
    padding: 40px 20px;
    text-align: center;
    color: var(--admin-muted);
    font-weight: 500;
    margin-bottom: 32px;
    transition: border-color 180ms ease, background-color 180ms ease;
  }

  .drop-zone.highlight {
    border-color: #7d5b2f;
    background: rgba(125, 91, 47, 0.05);
  }

  .media-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 20px;
  }

  .empty-media {
    grid-column: 1 / -1;
    text-align: center;
    padding: 48px;
    color: var(--admin-muted);
    border: 1px solid var(--admin-line);
    background: var(--admin-panel);
  }

  .media-card {
    border: 1px solid var(--admin-line);
    background: var(--admin-panel);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .media-preview {
    aspect-ratio: 4 / 3;
    background: #fdfdfd;
    border-bottom: 1px solid var(--admin-line);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .media-preview img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  .media-details {
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .media-name {
    font-size: 0.9rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .media-meta {
    font-size: 0.75rem;
    color: var(--admin-muted);
  }

  .media-url-input {
    width: 100%;
    font-size: 0.75rem;
    padding: 6px;
    background: var(--admin-bg);
    border: 1px solid var(--admin-line);
    color: var(--admin-muted);
    cursor: pointer;
    text-align: center;
  }

  .media-url-input:hover {
    color: var(--admin-text);
  }

  .delete-btn {
    border: 1px solid rgba(229, 83, 83, 0.4);
    background: transparent;
    color: #e55353;
    padding: 6px 12px;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    margin-top: 4px;
    transition: background 180ms ease, color 180ms ease;
  }

  .delete-btn:hover {
    background: #e55353;
    color: #fff;
  }
</style>
