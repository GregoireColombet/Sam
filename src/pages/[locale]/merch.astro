---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteNav from "@/components/SiteNav.astro";
import Footer from "@/components/Footer.astro";
import { getLandingContent, getMerchUrl } from "@/lib/db";
import { isLocale, labels, type Locale } from "@/lib/i18n";

export const prerender = false;

const requestedLocale = Astro.params.locale;
if (!isLocale(requestedLocale)) {
  return Astro.redirect("/zh-TW/merch");
}

const locale: Locale = requestedLocale;
const env = Astro.locals.runtime?.env;
const [landing, merchUrl] = await Promise.all([getLandingContent(env), getMerchUrl(env, locale)]);
const t = labels[locale];

if (merchUrl) {
  return Astro.redirect(merchUrl);
}
---

<BaseLayout locale={locale} title={`Sam Lee | ${t.merch}`}>
  <SiteNav locale={locale} merchUrl={merchUrl} />
  <main class="page-main">
    <section class="section">
      <div class="container">
        <h1 class="section-title">{t.merch}</h1>
        <div class="empty-state">{t.merchComingSoon}</div>
      </div>
    </section>
  </main>
  <Footer locale={locale} socialLinks={landing.socialLinks} />
</BaseLayout>

<style>
  .page-main {
    padding-top: 96px;
    min-height: 74vh;
    background: url('/assets/brushed_bg.jpg') no-repeat center;
    background-size: 100% 100%;
    color: #000000;
  }

  .page-main :global(.section-title) {
    color: #000000;
    text-shadow: none;
  }

  .page-main :global(.section-title::after) {
    background: #000000;
    box-shadow: none;
  }

  .page-main :global(.empty-state) {
    border-color: #000000;
    color: #000000;
  }
</style>
