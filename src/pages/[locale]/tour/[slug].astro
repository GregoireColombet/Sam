---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteNav from "@/components/SiteNav.astro";
import Footer from "@/components/Footer.astro";
import PlatformLinks from "@/components/PlatformLinks.astro";
import { getLandingContent, getMerchUrl, getTourBySlug } from "@/lib/db";
import { isLocale, labels, localePath, getLocalized, type Locale } from "@/lib/i18n";

export const prerender = false;

const requestedLocale = Astro.params.locale;
if (!isLocale(requestedLocale)) {
  return Astro.redirect("/zh-TW");
}

const locale: Locale = requestedLocale;
const slug = Astro.params.slug || "";
const env = Astro.locals.runtime?.env;
const [tourData, landing, merchUrl] = await Promise.all([
  getTourBySlug(env, slug),
  getLandingContent(env),
  getMerchUrl(env, locale)
]);
const t = labels[locale];
---

<BaseLayout locale={locale} title={`Sam Lee | ${t.tour}`}>
  <SiteNav locale={locale} merchUrl={merchUrl} />
  <main class="page-main">
    <section class="section">
      <div class="container">
        {tourData ? (
          <>
            <a class="back-link" href={`${localePath(locale)}#tour`}>{t.backHome}</a>
            <h1 class="section-title">{getLocalized(tourData.tour.location, locale)}</h1>
            <p class="tour-meta">{tourData.tour.localDate} · {tourData.tour.localTime} · {tourData.tour.timezone}</p>
            <p class="tour-description">{getLocalized(tourData.tour.description, locale)}</p>
            <h2>{t.ticketLinks}</h2>
            {tourData.links.length > 0 ? <PlatformLinks links={tourData.links} /> : <div class="empty-state">{t.comingSoon}</div>}

          </>
        ) : (
          <>
            <h1 class="section-title">{t.tour}</h1>
            <div class="empty-state">{t.tourComingSoon}</div>
          </>
        )}
      </div>
    </section>
  </main>
  <Footer locale={locale} socialLinks={landing.socialLinks} />
</BaseLayout>

<style>
  .page-main {
    padding-top: 96px;
    min-height: 74vh;
    background:
      linear-gradient(180deg, rgba(75, 187, 196, 0.08), transparent 280px),
      var(--bg);
  }

  .back-link {
    display: inline-flex;
    margin-bottom: 24px;
    color: var(--text-muted);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: color 180ms ease;
  }

  .back-link:hover {
    color: var(--cyan);
  }

  .tour-meta {
    color: var(--cyan);
    font-size: 1.1rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .tour-description {
    max-width: 720px;
    color: var(--text-muted);
    line-height: 1.8;
  }

  h2 {
    margin: 42px 0 18px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: #fff;
    position: relative;
    display: inline-block;
  }

  h2::after {
    content: "";
    display: block;
    width: 40px;
    height: 3px;
    background: var(--pink);
    margin-top: 6px;
    box-shadow: 0 0 8px var(--pink);
  }
</style>
