---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteNav from "@/components/SiteNav.astro";
import Footer from "@/components/Footer.astro";
import { getLandingContent, getMerchUrl } from "@/lib/db";
import { isLocale, labels, type Locale } from "@/lib/i18n";

export const prerender = false;

const requestedLocale = Astro.params.locale;
if (!isLocale(requestedLocale)) {
  return Astro.redirect("/zh-TW/about");
}

const locale: Locale = requestedLocale;
const env = Astro.locals.runtime?.env;
const [landing, merchUrl] = await Promise.all([
  getLandingContent(env),
  getMerchUrl(env, locale)
]);

const t = labels[locale];

const loremEn = "Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat. Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident.";
const loremTw = "這是設計的佔位文本。這是一段大約五十個字的中文預留文字。我們會在稍後將其替換為實際的關於李聖傑生平與音樂歷程的詳細內容。本段文字旨在展示排版與排版效果，確保時間軸和圓圈的佈局在所有語系中都能完美呈現，並與精美的背景風格相得益彰。";
const loremCn = "这是占位的文本。这是一段大约五十个字的中文预留文字。我们会在稍后将其替换为实际的关于李圣杰生平与音乐历程的详细内容。本段文字旨在展示排版与排版效果，确保时间轴和圆圈的布局在所有系中都能完美呈现，并与精美的背景风格相得益彰。";

const localData = {
  en: {
    title: "About Sam Lee",
    sections: [
      {
        title: "Debut & Music Journey",
        image: "/assets/about/about_debut.jpg",
        alt: "Sam Lee performing live on stage",
        items: [
          { year: "2011", text: loremEn },
          { year: "2012", text: loremEn },
          { year: "2013", text: loremEn },
          { year: "2014", text: loremEn },
          { year: "2015", text: loremEn }
        ]
      },
      {
        title: "Tennis Passion",
        image: "/assets/about/about_tennis.jpg",
        alt: "Professional tennis court and equipment representing Sam's tennis career",
        items: [
          { year: "2016", text: loremEn },
          { year: "2017", text: loremEn },
          { year: "2018", text: loremEn },
          { year: "2019", text: loremEn },
          { year: "2020", text: loremEn }
        ]
      },
      {
        title: "Zoommuzik Venture",
        image: "/assets/about/about_venture.jpg",
        alt: "Modern independent music studio representing Zoommuzik",
        items: [
          { year: "2021", text: loremEn },
          { year: "2022", text: loremEn },
          { year: "2023", text: loremEn },
          { year: "2024", text: loremEn },
          { year: "2025", text: loremEn }
        ]
      }
    ]
  },
  "zh-TW": {
    title: "關於李聖傑",
    sections: [
      {
        title: "歌手生涯與音樂之路",
        image: "/assets/about/about_debut.jpg",
        alt: "李聖傑舞台歌唱表演",
        items: [
          { year: "2011", text: loremTw },
          { year: "2012", text: loremTw },
          { year: "2013", text: loremTw },
          { year: "2014", text: loremTw },
          { year: "2015", text: loremTw }
        ]
      },
      {
        title: "網球運動與熱情",
        image: "/assets/about/about_tennis.jpg",
        alt: "精美網球拍與球場",
        items: [
          { year: "2016", text: loremTw },
          { year: "2017", text: loremTw },
          { year: "2018", text: loremTw },
          { year: "2019", text: loremTw },
          { year: "2020", text: loremTw }
        ]
      },
      {
        title: "錞藝音樂 Zoommuzik",
        image: "/assets/about/about_venture.jpg",
        alt: "錞藝音樂工作室",
        items: [
          { year: "2021", text: loremTw },
          { year: "2022", text: loremTw },
          { year: "2023", text: loremTw },
          { year: "2024", text: loremTw },
          { year: "2025", text: loremTw }
        ]
      }
    ]
  },
  "zh-CN": {
    title: "关于李圣杰",
    sections: [
      {
        title: "歌手生涯与音乐之路",
        image: "/assets/about/about_debut.jpg",
        alt: "李圣杰舞台歌唱表演",
        items: [
          { year: "2011", text: loremCn },
          { year: "2012", text: loremCn },
          { year: "2013", text: loremCn },
          { year: "2014", text: loremCn },
          { year: "2015", text: loremCn }
        ]
      },
      {
        title: "网球运动与热情",
        image: "/assets/about/about_tennis.jpg",
        alt: "精美网球拍与球场",
        items: [
          { year: "2016", text: loremCn },
          { year: "2017", text: loremCn },
          { year: "2018", text: loremCn },
          { year: "2019", text: loremCn },
          { year: "2020", text: loremCn }
        ]
      },
      {
        title: "錞艺音乐 Zoommuzik",
        image: "/assets/about/about_venture.jpg",
        alt: "錞艺音乐工作室",
        items: [
          { year: "2021", text: loremCn },
          { year: "2022", text: loremCn },
          { year: "2023", text: loremCn },
          { year: "2024", text: loremCn },
          { year: "2025", text: loremCn }
        ]
      }
    ]
  }
};

const currentData = localData[locale];
---

<BaseLayout locale={locale} title={`Sam Lee | ${t.about}`}>
  <SiteNav locale={locale} merchUrl={merchUrl} />
  <main class="page-main">
    <section class="section hero-section">
      <div class="container text-center">
        <h1 class="page-title">{currentData.title}</h1>
        <div class="divider"></div>
      </div>
    </section>

    <!-- Section 1: 2011 - 2015 (Image left, Timeline right, brushed bg, pink line) -->
    <section class="about-section section-1">
      <div class="container">
        <div class="about-grid">
          <div class="image-wrapper">
            <img src={currentData.sections[0].image} alt={currentData.sections[0].alt} loading="lazy" class="about-image" />
            <div class="image-overlay"></div>
          </div>
          <div class="timeline-container">
            {currentData.sections[0].items.map((item) => (
              <div class="timeline-item">
                <div class="timeline-circle">
                  <span class="year-text">{item.year}</span>
                </div>
                <div class="timeline-content">
                  <p class="paragraph">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: 2016 - 2020 (Timeline left, Image right, blue bg, blue line) -->
    <section class="about-section section-2">
      <div class="container">
        <div class="about-grid">
          <div class="timeline-container">
            {currentData.sections[1].items.map((item) => (
              <div class="timeline-item">
                <div class="timeline-circle">
                  <span class="year-text">{item.year}</span>
                </div>
                <div class="timeline-content">
                  <p class="paragraph">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
          <div class="image-wrapper">
            <img src={currentData.sections[1].image} alt={currentData.sections[1].alt} loading="lazy" class="about-image" />
            <div class="image-overlay"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: 2021 - 2025 (Image left, Timeline right, flipped brushed bg, pink line) -->
    <section class="about-section section-3">
      <div class="section-flipped-bg"></div>
      <div class="container">
        <div class="about-grid">
          <div class="image-wrapper">
            <img src={currentData.sections[2].image} alt={currentData.sections[2].alt} loading="lazy" class="about-image" />
            <div class="image-overlay"></div>
          </div>
          <div class="timeline-container">
            {currentData.sections[2].items.map((item) => (
              <div class="timeline-item">
                <div class="timeline-circle">
                  <span class="year-text">{item.year}</span>
                </div>
                <div class="timeline-content">
                  <p class="paragraph">{item.text}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer locale={locale} socialLinks={landing.socialLinks} />
</BaseLayout>

<style>
  .page-main {
    padding-top: 96px;
    min-height: 80vh;
    background: transparent;
    color: #000000;
  }

  .text-center {
    text-align: center;
  }

  .hero-section {
    padding-bottom: 48px;
    background: url('/assets/brushed_bg.jpg') no-repeat center;
    background-size: cover;
  }

  .page-title {
    margin: 0;
    font-size: clamp(2.5rem, 6vw, 4.8rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: #000000;
    text-transform: uppercase;
    text-shadow: none;
  }

  .divider {
    width: 60px;
    height: 4px;
    background: #000000;
    margin: 24px auto 0;
    border-radius: 2px;
    box-shadow: none;
  }

  .about-section {
    padding: 80px 0;
    position: relative;
    overflow: hidden;
  }

  /* Section 1: Brushed Background, Pink/Rose line and details */
  .section-1 {
    background: url('/assets/brushed_bg.jpg') no-repeat center;
    background-size: cover;
    color: #000000;
    --line-color: var(--rose);
  }

  /* Section 2: Blue Background, Cyan/Blue line and details */
  .section-2 {
    background: linear-gradient(135deg, #060c18 0%, #0d1e36 100%);
    color: #ffffff;
    --line-color: var(--cyan);
  }

  /* Section 3: Flipped Brushed Background, Pink/Rose line and details */
  .section-3 {
    background: transparent;
    color: #000000;
    --line-color: var(--rose);
  }

  .section-flipped-bg {
    position: absolute;
    inset: 0;
    background: url('/assets/brushed_bg.jpg') no-repeat center;
    background-size: cover;
    transform: scaleX(-1);
    z-index: 1;
    pointer-events: none;
  }

  .section-3 .container {
    position: relative;
    z-index: 2;
  }

  /* Grid Layout */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 80px;
    align-items: center;
    position: relative;
  }

  /* Desktop layout ordering */
  .section-1 .image-wrapper,
  .section-3 .image-wrapper {
    grid-column: 1;
  }
  .section-1 .timeline-container,
  .section-3 .timeline-container {
    grid-column: 2;
  }

  .section-2 .timeline-container {
    grid-column: 1;
  }
  .section-2 .image-wrapper {
    grid-column: 2;
  }

  /* Continuous timeline line on desktop */
  .about-grid::before {
    content: "";
    position: absolute;
    top: -80px;
    bottom: -80px;
    left: 50%;
    width: 4px;
    background-color: var(--line-color);
    transform: translateX(-50%);
    z-index: 2;
  }

  /* Image wrappers */
  .image-wrapper {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16 / 10;
    border: 2px solid currentColor;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
    z-index: 3;
  }

  .section-2 .image-wrapper {
    box-shadow: 0 10px 30px rgba(75, 187, 196, 0.15);
  }

  .image-wrapper:hover {
    transform: translateY(-8px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.25);
  }

  .section-2 .image-wrapper:hover {
    box-shadow: 0 15px 35px rgba(75, 187, 196, 0.25);
  }

  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .image-wrapper:hover .about-image {
    transform: scale(1.05);
  }

  .image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.15));
    pointer-events: none;
  }

  /* Timeline Container and Items */
  .timeline-container {
    display: flex;
    flex-direction: column;
    gap: 48px;
    position: relative;
    z-index: 3;
  }

  .timeline-item {
    position: relative;
    min-height: 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* Alignments for Desktop */
  .section-1 .timeline-item,
  .section-3 .timeline-item {
    padding-left: 56px;
    text-align: left;
  }

  .section-2 .timeline-item {
    padding-right: 56px;
    text-align: right;
  }

  /* Timeline Circles showing year */
  .timeline-circle {
    position: absolute;
    top: 50%;
    width: 72px;
    height: 72px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 3px solid var(--line-color);
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    z-index: 5;
  }

  /* Desktop circle positioning */
  .section-1 .timeline-circle,
  .section-3 .timeline-circle {
    left: 0;
    transform: translate(-50%, -50%);
    background-color: #ffffff;
  }

  .section-2 .timeline-circle {
    right: 0;
    transform: translate(50%, -50%);
    background-color: #0b1528;
  }

  .year-text {
    font-size: 1.1rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: currentColor;
  }

  .section-1 .year-text,
  .section-3 .year-text {
    color: #000000;
  }

  .section-2 .year-text {
    color: #ffffff;
  }

  .timeline-content {
    background: transparent;
  }

  .paragraph {
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.9;
    text-align: justify;
  }

  .section-1 .paragraph,
  .section-3 .paragraph {
    color: #2b2b2b;
  }

  .section-2 .paragraph {
    color: #e2e8f0;
  }

  /* Responsive Design */
  @media (max-width: 960px) {
    .hero-section {
      padding-bottom: 24px;
    }

    .about-section {
      padding: 48px 0;
    }

    .about-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    /* Reset desktop column ordering on mobile */
    .section-1 .image-wrapper,
    .section-2 .image-wrapper,
    .section-3 .image-wrapper {
      grid-column: auto;
      order: 1;
    }

    .section-1 .timeline-container,
    .section-2 .timeline-container,
    .section-3 .timeline-container {
      grid-column: auto;
      order: 2;
      padding-left: 52px;
    }

    /* Hide the desktop center line on mobile */
    .about-grid::before {
      display: none;
    }

    /* Create left-aligned line on the timeline container on mobile */
    .timeline-container::before {
      content: "";
      position: absolute;
      top: 0;
      bottom: 0;
      left: 0;
      width: 4px;
      background-color: var(--line-color);
      z-index: 2;
    }

    /* Standardize timeline item alignment on mobile */
    .timeline-item {
      padding-left: 24px !important;
      padding-right: 0 !important;
      text-align: left !important;
      min-height: 60px;
    }

    /* Standardize circles on mobile */
    .timeline-circle {
      left: 0 !important;
      right: auto !important;
      transform: translate(-50%, -50%) !important;
      width: 56px;
      height: 56px;
      border-width: 2.5px;
    }

    .year-text {
      font-size: 0.95rem;
    }
  }
</style>
