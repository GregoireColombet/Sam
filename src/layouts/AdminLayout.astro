---
type Props = {
  title: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Sam Admin</title>
  </head>
  <body>
    <aside>
      <a class="admin-brand" href="/sam-admin">Sam Admin</a>
      <nav>
        <a href="/sam-admin">Dashboard</a>
        <a href="/sam-admin/content">Content</a>
        <a href="/sam-admin/media">Media</a>
        <a href="/sam-admin/users">Users</a>
        <a href="/sam-admin/activity">Activity</a>
      </nav>
    </aside>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --admin-bg: #f5f4f1;
    --admin-panel: #fff;
    --admin-text: #181818;
    --admin-muted: #68645f;
    --admin-line: #dedbd4;
    --admin-accent: #7d5b2f;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    display: grid;
    grid-template-columns: 248px minmax(0, 1fr);
    background: var(--admin-bg);
    color: var(--admin-text);
  }

  aside {
    position: sticky;
    top: 0;
    height: 100vh;
    padding: 24px;
    border-right: 1px solid var(--admin-line);
    background: #111;
    color: #fff;
  }

  main {
    padding: 32px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .admin-brand {
    display: block;
    margin-bottom: 32px;
    font-size: 1.2rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  nav {
    display: grid;
    gap: 8px;
  }

  nav a {
    padding: 10px 12px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.78);
  }

  nav a:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.32);
  }

  h1 {
    margin: 0 0 8px;
    font-size: clamp(2rem, 4vw, 3.4rem);
    letter-spacing: 0;
  }

  .admin-muted {
    color: var(--admin-muted);
  }

  .admin-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 16px;
    margin-top: 28px;
  }

  .admin-card {
    border: 1px solid var(--admin-line);
    background: var(--admin-panel);
    padding: 18px;
  }

  .admin-card h2 {
    margin: 0 0 8px;
    font-size: 1.05rem;
  }

  .admin-card p {
    margin: 0;
    color: var(--admin-muted);
    line-height: 1.55;
  }

  .admin-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 24px;
    background: #fff;
  }

  .admin-table th,
  .admin-table td {
    padding: 12px;
    border-bottom: 1px solid var(--admin-line);
    text-align: left;
  }

  @media (max-width: 820px) {
    body {
      grid-template-columns: 1fr;
    }

    aside {
      position: static;
      height: auto;
    }

    main {
      padding: 20px;
    }
  }
</style>
