---
import type { Locale } from "@/lib/i18n";

type Props = {
  locale: Locale;
  title?: string;
  description?: string;
};

const { locale, title = "Sam Lee", description = "Official website of Sam Lee." } = Astro.props;
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#080808" />
    
    <!-- OpenGraph SEO -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content={locale === "zh-TW" ? "zh_TW" : locale === "zh-CN" ? "zh_CN" : "en_US"} />
    <meta property="og:site_name" content="Sam Lee" />
    
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <title>{title}</title>
    <link rel="icon" href="/favicon.svg" />
  </head>
  <body>
    <slot />
    <script>
      const nav = document.querySelector("[data-site-nav]");
      const menuButton = document.querySelector("[data-menu-button]");
      const mobileMenu = document.querySelector("[data-mobile-menu]");
      const updateNav = () => nav?.classList.toggle("is-scrolled", window.scrollY > 16);
      updateNav();
      window.addEventListener("scroll", updateNav, { passive: true });
      menuButton?.addEventListener("click", () => {
        const expanded = menuButton.getAttribute("aria-expanded") === "true";
        menuButton.setAttribute("aria-expanded", String(!expanded));
        mobileMenu?.classList.toggle("is-open", !expanded);
      });
      document.querySelectorAll("[data-scroll-tour]").forEach((link) => {
        link.addEventListener("click", (event) => {
          const target = document.querySelector("#tour");
          if (target) {
            event.preventDefault();
            mobileMenu?.classList.remove("is-open");
            menuButton?.setAttribute("aria-expanded", "false");
            target.scrollIntoView({ behavior: "smooth", block: "start" });
          }
        });
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
    --bg: #080808;
    --bg-soft: #141414;
    --bg-muted: #222;
    --text: #f7f3ec;
    --text-muted: #bdb6aa;
    --line: rgba(255, 255, 255, 0.14);
    --gold: #cfa968;
    --rose: #b85c5f;
    --jade: #6fb39c;
    --max: 1160px;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      "Noto Sans TC", "Noto Sans SC", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background: var(--bg);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  video,
  iframe {
    max-width: 100%;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  .container {
    width: min(100% - 32px, var(--max));
    margin-inline: auto;
  }

  .section {
    padding: 72px 0;
  }

  .section-title {
    margin: 0 0 24px;
    font-size: clamp(2rem, 5vw, 4.4rem);
    line-height: 0.95;
    font-weight: 800;
    letter-spacing: 0;
  }

  .muted {
    color: var(--text-muted);
  }

  .empty-state {
    border: 1px solid var(--line);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
    padding: 32px;
    min-height: 160px;
    display: grid;
    place-items: center;
    text-align: center;
    color: var(--text-muted);
  }

  .external-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 16px;
  }

  .platform-link {
    min-height: 132px;
    border: 1px solid var(--line);
    background: #101010;
    display: grid;
    place-items: center;
    gap: 12px;
    padding: 18px;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background 180ms ease;
  }

  .platform-link:hover {
    transform: translateY(-3px);
    border-color: rgba(207, 169, 104, 0.65);
    background: #181512;
  }

  .platform-link img {
    width: 96px;
    height: 48px;
    object-fit: contain;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border: 1px solid rgba(255, 255, 255, 0.26);
    background: var(--text);
    color: #0c0c0c;
    font-weight: 700;
    transition:
      transform 180ms ease,
      background 180ms ease;
  }

  .button:hover {
    transform: translateY(-2px);
    background: var(--gold);
  }

  @media (max-width: 720px) {
    .section {
      padding: 52px 0;
    }

    .container {
      width: min(100% - 24px, var(--max));
    }
  }
</style>
